# ─── Supabase (provisioned in a later step — leave blank for Phase 0) ───
# The public URL of the Gary Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
# The publishable (anon) key for client-side access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# The service-role key for trusted server-side access. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Active reasoning layer ───
# API key for the reasoning layer's LLM provider.
ANTHROPIC_API_KEY=
# Model used by the active reasoning layer. Defaults to the latest, most capable
# model when unset (see src/config/decisions.ts).
ANTHROPIC_MODEL=

# ─── Ecosphere Core integration (source of truth for prices) ───
# Base URL of the Core pricing service. Gary owns BOM quantities; Core owns prices.
CORE_API_BASE_URL=
CORE_API_KEY=
