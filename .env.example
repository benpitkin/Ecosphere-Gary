# ─── Supabase (provisioned in a later step — leave blank for Phase 0) ───
# The public URL of the Gary Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
# The publishable (anon) key for client-side access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# The service-role key for trusted server-side access. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Active reasoning layer ───
# API key for the reasoning layer's LLM provider.
ANTHROPIC_API_KEY=
# Model used by the active reasoning layer. Defaults to the latest, most capable
# model when unset (see src/config/decisions.ts).
ANTHROPIC_MODEL=

# ─── Inbound API authentication (machine-to-machine) ───
# When SET, Gary requires callers (Core, etc.) to present this key on every
# /api/* call as `Authorization: Bearer <key>` or `x-api-key: <key>`.
# When UNSET, the endpoints are open (fine for local dev; set it once deployed).
# Generate a long random string, e.g.  openssl rand -hex 32
# NOTE: the internal browser pages (/triage, /design, /solar) call these routes
# client-side and won't carry the key — when enforcement is on, run those behind
# platform SSO, or keep GARY_API_KEY unset where staff use the browser UI.
GARY_API_KEY=

# ─── Ecosphere Core integration (source of truth for prices) ───
# Base URL of the Core pricing service. Gary owns BOM quantities; Core owns prices.
CORE_API_BASE_URL=
CORE_API_KEY=

# ─── OpenSolar integration (initial solar PV designs) ───
# Without these, the OpenSolar adapter is unconfigured and its calls no-op.
OPENSOLAR_API_TOKEN=
OPENSOLAR_ORG_ID=
# Optional; defaults to https://api.opensolar.com
OPENSOLAR_BASE_URL=

# ─── EPC lookup (triage from just an address) ───
# Without this, triage takes property data as direct input (no address lookup).
# Free key from the England & Wales EPC register (epc.opendatacommunities.org).
EPC_API_KEY=
