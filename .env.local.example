# Local development env — copy to .env.local and fill from `npm run db:status`.
#
#   npm run db:start      # boots the local Supabase stack (Docker)
#   npm run db:status     # prints the local URL + keys to paste below
#   npm run dev           # http://localhost:3000
#
# Local Supabase serves its API at this fixed URL:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Paste the "anon key" / publishable key from `npm run db:status`:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Paste the "service_role key" / secret key from `npm run db:status`:
SUPABASE_SERVICE_ROLE_KEY=

# Active reasoning layer — optional locally (calls are stubbed in Phase 0):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Ecosphere Core — no local mock yet; leave blank to run Gary standalone:
CORE_API_BASE_URL=
CORE_API_KEY=
